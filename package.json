{
  "name": "888tiannan-watermark-desktop",
  "version": "0.1.3",
  "description": "今日水印相机 Electron desktop app.",
  "author": "xiaotiannan",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dist": "electron-builder --win nsis --x64"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.xiaotiannan.watermark",
    "productName": "今日水印相机",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "docs/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
